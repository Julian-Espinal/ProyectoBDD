<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.controller.MainLayoutController"
            stylesheets="@app.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="300" spacing="14">
            <padding>
                <Insets top="32" right="20" bottom="32" left="20"/>
            </padding>

            <Label text="ACADEMIA" styleClass="sidebar-title"/>

            <Region prefHeight="24"/>

            <Button text="Estudiante" styleClass="menu-button" maxWidth="Infinity" onAction="#onEstudiante"/>
            <Button text="Asignatura" styleClass="menu-button" maxWidth="Infinity" onAction="#onAsignatura"/>
            <Button text="Horario de grupo" styleClass="menu-button" maxWidth="Infinity" onAction="#onHorarioGrupo"/>
            <Button text="Inscripcion de grupos" styleClass="menu-button" maxWidth="Infinity" onAction="#onInscripcion"/>
            <Button text="Horario cuadriculado" styleClass="menu-button" maxWidth="Infinity" onAction="#onHorarioCuadriculado"/>
            <Button text="Informe de inscripcion" styleClass="menu-button" maxWidth="Infinity" onAction="#onInforme"/>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <Label text="Selecciona una opcion del menu" styleClass="content-placeholder"/>
        </StackPane>
    </center>

</BorderPane>
