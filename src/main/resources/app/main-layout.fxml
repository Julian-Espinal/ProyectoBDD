<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@app.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controller.MainLayoutController">

    <left>
        <VBox prefWidth="300" spacing="14" styleClass="sidebar">
            <padding>
                <Insets bottom="32" left="20" right="20" top="32" />
            </padding>

            <Label styleClass="sidebar-title" text="ACADEMIA" />

            <Region prefHeight="24" />

            <Button maxWidth="Infinity" onAction="#onEstudiante" styleClass="menu-button" text="Estudiante" />
            <Button maxWidth="Infinity" onAction="#onAsignatura" styleClass="menu-button" text="Asignatura" />
            <Button maxWidth="Infinity" onAction="#onHorarioGrupo" styleClass="menu-button" text="Horario de grupo" />
            <Button maxWidth="Infinity" onAction="#onInscripcion" styleClass="menu-button" text="Inscripcion de grupos" />

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <Label styleClass="content-placeholder" text="Selecciona una opcion del menu" />
        </StackPane>
    </center>

</BorderPane>
