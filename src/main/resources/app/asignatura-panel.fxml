<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.controller.AsignaturaPanelController"
      spacing="16">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>


    <Label text="Asignatura"
           styleClass="panel-titulo"/>


    <HBox spacing="10">

        <Button text="Añadir"
                styleClass="btn-primary"
                onAction="#onAnadir"/>

        <Button text="Modificar"
                styleClass="btn-secondary"
                onAction="#onModificar"/>

        <Button text="Eliminar"
                styleClass="btn-danger"
                onAction="#onEliminar"/>

    </HBox>


    <TableView fx:id="tablaAsignaturas"
               VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="colCodigo"
                         text="Código"
                         prefWidth="120"/>

            <TableColumn fx:id="colNombre"
                         text="Nombre"
                         prefWidth="180"/>

            <TableColumn fx:id="colCreditos"
                         text="Créditos"
                         prefWidth="100"/>

            <TableColumn fx:id="colHorasTeoricas"
                         text="Horas Teóricas"
                         prefWidth="120"/>

            <TableColumn fx:id="colHorasPracticas"
                         text="Horas Prácticas"
                         prefWidth="120"/>

        </columns>

    </TableView>


</VBox>